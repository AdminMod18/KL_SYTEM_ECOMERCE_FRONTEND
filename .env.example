# --- Desarrollo (Vite) ---
# Prefijo servido por el proxy: /api → microservicios locales (ver vite.config.js).
VITE_API_URL=/api

# --- Producción (build) ---
# URL absoluta del API Gateway o backend público.
# VITE_API_URL=https://api.midominio.com

# Admin / parametrización (admin-service, puerto 9010 en local). En dev: proxy `/api/admin`.
# VITE_ADMIN_URL=https://api.midominio.com/admin

# Timeout HTTP (ms)
VITE_API_TIMEOUT=20000

# Peticiones axios pueden usar { skipGlobalLoading: true } en la config para no sumar al overlay global
# (útil junto a spinners locales, p. ej. listados con skeleton).
